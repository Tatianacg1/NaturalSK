# Configuración de Nginx para servir NaturalSK (SPA + Backend)
#
# UBICACIÓN: /etc/nginx/sites-available/naturalsound
# Instalación:
#   1. Copiar este archivo a: /etc/nginx/sites-available/naturalsound
#   2. Crear symlink: sudo ln -s /etc/nginx/sites-available/naturalsound /etc/nginx/sites-enabled/naturalsound
#   3. Testear config: sudo nginx -t
#   4. Recargar: sudo systemctl reload nginx

server {
  listen 80;
  server_name naturalsound.com www.naturalsound.com;  # Reemplaza con tu dominio

  # Redirigir HTTP → HTTPS (opcional, para producción)
  # return 301 https://$server_name$request_uri;
}

# HTTPS (descomenta después de instalar certificado SSL)
# server {
#   listen 443 ssl http2;
#   server_name naturalsound.com www.naturalsound.com;
#
#   ssl_certificate /etc/letsencrypt/live/naturalsound.com/fullchain.pem;
#   ssl_certificate_key /etc/letsencrypt/live/naturalsound.com/privkey.pem;
# }

server {
  listen 80;
  listen [::]:80;
  server_name naturalsound.com www.naturalsound.com;

  # Comprimir respuestas
  gzip on;
  gzip_types text/plain text/css application/json application/javascript;

  # === Backend API ===
  location /api/ {
    proxy_pass http://localhost:5000;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection 'upgrade';
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_cache_bypass $http_upgrade;
  }

  # === Frontend SPA (archivos estáticos) ===
  location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
    root /var/www/naturalsound/dist;  # Ruta a los archivos buildados
    expires 1h;
    add_header Cache-Control "public, immutable";
  }

  # === SPA Fallback: todas las demás rutas sirven index.html ===
  location / {
    root /var/www/naturalsound/dist;  # Ruta a los archivos buildados
    try_files $uri /index.html;
  }

  # Logs
  access_log /var/log/nginx/naturalsound_access.log;
  error_log /var/log/nginx/naturalsound_error.log;
}
